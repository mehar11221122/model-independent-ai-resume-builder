# ---------------------------------------------------------------------------
# OpenRouter (model gateway - REQUIRED)
# https://openrouter.ai/keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing - these are OpenRouter model slugs.
# Change providers/models here without touching any code.
MODEL_PRIMARY=anthropic/claude-sonnet-4
MODEL_FALLBACK=openai/gpt-4o
MODEL_LIGHTWEIGHT=openai/gpt-4o-mini

# --- $0-cost alternative -----------------------------------------------
# OpenRouter has no subscription fee - you only pay per-token for paid
# models. Models with a ":free" suffix cost nothing at all (rate-limited
# to ~20 req/min / 200 req/day per OpenRouter). To run the whole engine for
# free, comment out the three lines above and uncomment these instead:
# MODEL_PRIMARY=nvidia/nemotron-3-super-120b-a12b:free
# MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free
# MODEL_LIGHTWEIGHT=nvidia/nemotron-nano-9b-v2:free
# Free model slugs rotate in and out of availability - if one 404s with
# "unavailable for free", swap it for another from the current list:
# https://openrouter.ai/models?max_price=0

# Hard per-attempt timeout (seconds) for a single LLM call, so a congested
# free model fails fast into a retry instead of hanging past whatever
# timeout a reverse proxy in front of this app enforces (e.g. Cloudflare's
# free-tier ~100s edge timeout, which otherwise surfaces as an opaque 524).
# LLM_REQUEST_TIMEOUT_SECONDS=20

# --- Token/cost optimization (safe defaults, override only if you need to) --
# Output-length ceilings per call type - a safety cap, not a quality limit
# (sized generously for a long multi-job resume already):
# MAX_TOKENS_EXTRACT=2000
# MAX_TOKENS_CHECK_ANSWERS=800
# MAX_TOKENS_TOOL_USE=500
# MAX_TOKENS_GENERATE=3000
#
# Exact-match response cache (app/llm/cache.py) - skips the model entirely
# (zero tokens/quota/latency) on a byte-identical repeat call. Only matches
# identical input, so there's no cross-user leakage risk to guard against:
# LLM_CACHE_ENABLED=true
# LLM_CACHE_MAX_ENTRIES=512
# LLM_CACHE_TTL_SECONDS=3600

# --- Optional: secondary free-tier providers (recommended before launch) ---
# OpenRouter's free quota (50 req/day, or 1000/day if you've ever added the
# one-time $10 credit) is ONE pool shared across every ":free" model on your
# account - so an OpenRouter "fallback" model above adds zero extra daily
# capacity once that shared pool is used up, only redundancy against one
# model being briefly congested. Groq and Google Gemini are separate
# companies with their own, completely independent free daily quotas, and
# `get_model_with_fallback()` (app/llm/router.py) automatically chains them
# on as extra fallback links whenever a key is set below - no card needed
# for either signup. This is the recommended way to raise real capacity
# ahead of a launch/pilot without giving up "no cards, no upfront payment".
#
# Groq (https://console.groq.com/keys) - ~14,400 free req/day on its 8B
# model, ~1,000 free req/day on its bigger 70B/120B models:
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
# GROQ_MODEL_LIGHTWEIGHT=llama-3.1-8b-instant
#
# Google Gemini (https://aistudio.google.com/apikey) - ~250-1,500 free
# req/day depending on model, via Gemini's OpenAI-compatibility endpoint.
# Use the "-latest" alias slugs, not pinned versions like gemini-2.5-flash -
# fresh free-tier keys can get a 404 "no longer available to new users" on
# pinned versions even though the API still lists them:
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL_PRIMARY=gemini-flash-lite-latest
# GEMINI_MODEL_LIGHTWEIGHT=gemini-flash-lite-latest

# ---------------------------------------------------------------------------
# State persistence (workflow checkpointing)
# CHECKPOINT_BACKEND = memory | sqlite | postgres
# ---------------------------------------------------------------------------
CHECKPOINT_BACKEND=sqlite
SQLITE_CHECKPOINT_PATH=./data/checkpoints.sqlite
# Free managed-Postgres alternatives to a self-hosted server: Neon or
# Supabase free tiers both work as a drop-in DSN here.
POSTGRES_DSN=postgresql://user:password@localhost:5432/ai_engine

# ---------------------------------------------------------------------------
# OCR
# OCR_BACKEND = tesseract | google_vision | aws_textract
# ---------------------------------------------------------------------------
OCR_BACKEND=tesseract
TESSERACT_CMD=

# ---------------------------------------------------------------------------
# File storage
# STORAGE_BACKEND = local | s3
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/uploads
# If you outgrow local disk, Cloudflare R2's free tier (10GB, zero egress
# fees, S3-compatible API) works as a drop-in swap - set STORAGE_BACKEND=s3
# and fill in these fields (for R2, S3_ENDPOINT_URL is the R2 account
# endpoint, e.g. https://<account_id>.r2.cloudflarestorage.com; leave blank
# for real AWS S3).
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_ENDPOINT_URL=

# ---------------------------------------------------------------------------
# API auth
# ---------------------------------------------------------------------------
API_AUTH_ENABLED=false
API_KEY=change-me

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-engine

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
